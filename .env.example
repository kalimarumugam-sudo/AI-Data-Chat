# OpenAI (default LLM provider)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Oracle database (advanced feature)
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=hostname:1521/service_name
ORACLE_THICK_MODE=false

# Optional: AWS Bedrock (alternative LLM provider)
# Switch providers in src/ai_service.py
AWS_REGION=us-east-1
AWS_PROFILE=default
BEDROCK_LLM_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
